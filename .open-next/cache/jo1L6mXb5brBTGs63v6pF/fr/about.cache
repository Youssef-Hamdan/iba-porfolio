{"type":"app","meta":{"headers":{"x-nextjs-stale-time":"300","x-nextjs-prerender":"1","x-next-cache-tags":"_N_T_/layout,_N_T_/[locale]/layout,_N_T_/[locale]/about/layout,_N_T_/[locale]/about/page,_N_T_/fr/about"},"segmentPaths":["/_tree","/_full","/$d$locale/about/__PAGE__","/$d$locale/about","/$d$locale","/_index","/_head"]},"html":"<!DOCTYPE html><html lang=\"fr\" class=\"montserrat_2f6ba378-module__x6Ry1W__variable noto_sans_sc_62fcb68c-module__a5Wmsq__variable h-full\"><head><meta charSet=\"utf-8\"/><meta name=\"viewport\" content=\"width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no\"/><link rel=\"preload\" href=\"/_next/static/media/e8f2fbee2754df70-s.p.1dqa_6e_ad4sj.woff2\" as=\"font\" crossorigin=\"\" type=\"font/woff2\"/><link rel=\"preload\" as=\"image\" href=\"/images/logo/iba-logo-horiz.png\"/><link rel=\"preload\" as=\"image\" href=\"/images/logo/iba-logo.png\"/><link rel=\"stylesheet\" href=\"/_next/static/chunks/022gs8qoowb0b.css\" data-precedence=\"next\"/><link rel=\"stylesheet\" href=\"/_next/static/chunks/18cuhvsj_eyv_.css\" data-precedence=\"next\"/><link rel=\"stylesheet\" href=\"/_next/static/chunks/24cef9bxfb8kx.css\" data-precedence=\"next\"/><link rel=\"preload\" as=\"script\" fetchPriority=\"low\" href=\"/_next/static/chunks/0iq1i69206cyl.js\"/><script src=\"/_next/static/chunks/1hiaq_920y_5l.js\" async=\"\"></script><script src=\"/_next/static/chunks/3p9eevrhj-twl.js\" async=\"\"></script><script src=\"/_next/static/chunks/turbopack-2zcxhqcfeu1us.js\" async=\"\"></script><script src=\"/_next/static/chunks/05-c3ty_6dwfk.js\" async=\"\"></script><script src=\"/_next/static/chunks/14mrh2-p_w84d.js\" async=\"\"></script><script src=\"/_next/static/chunks/03ri202u19u7-.js\" async=\"\"></script><script src=\"/_next/static/chunks/0b1yzoh5q690f.js\" async=\"\"></script><script src=\"/_next/static/chunks/0oq3s7ezb9wrl.js\" async=\"\"></script><meta name=\"next-size-adjust\" content=\"\"/><meta name=\"theme-color\" content=\"#ffff