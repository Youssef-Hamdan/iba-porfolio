\\"ctaTitle\\\":\\\"Architectural ambition.\\\",\\\"ctaDescription\\\":\\\"A selection of projects showcasing our technical mastery and tangible impact on infrastructure.\\\",\\\"ctaButton\\\":\\\"View projects\\\",\\\"ctaImageAlt\\\":\\\"Flagship projects\\\",\\\"collections\\\":{\\\"acierFer\\\":{\\\"title\\\":\\\"Steel \\u0026 Iron\\\",\\\"desc\\\":\\\"Sheets, profiles, and steel tubes for robust structures.\\\"},\\\"ciments\\\":{\\\"title\\\":\\\"Cements\\\",\\\"desc\\\":\\\"Hydraulic binders and bagged cements — only.\\\"},\\\"beton\\\":{\\\"title\\\":\\\"Ready-Mix Concrete\\\",\\\"desc\\\":\\\"Ready-mix concrete delivered directly to your sites.\\\"},\\\"brique\\\":{\\\"title\\\":\\\"Brick\\\",\\\"desc\\\":\\\"High-quality solid and hollow construction bricks.\\\"},\\\"peinture\\\":{\\\"title\\\":\\\"Paint\\\",\\\"desc\\\":\\\"Paints and mastics for lasting finishes.\\\"},\\\"bois\\\":{\\\"title\\\":\\\"Wood\\\",\\\"desc\\\":\\\"Timber for framing, formwork, and joinery.\\\"},\\\"outillage\\\":{\\\"title\\\":\\\"JKL Tools \\u0026 Hardware\\\",\\\"desc\\\":\\\"Professional tools and general hardware.\\\"},\\\"plafonds\\\":{\\\"title\\\":\\\"Ceilings\\\",\\\"desc\\\":\\\"Complete solutions for suspended ceilings and insulation.\\\"},\\\"panneaux\\\":{\\\"title\\\":\\\"Sandwich Panels\\\",\\\"desc\\\":\\\"Insulating panels for industrial roofs and cladding.\\\"},\\\"pave\\\":{\\\"title\\\":\\\"Paving Stones\\\",\\\"desc\\\":\\\"Interlocking paving stones for outdoor spaces.\\\"},\\\"transport\\\":{\\\"title\\\":\\\"Transport Service\\\",\\\"desc\\\":\\\"Fast and secure delivery of all your materials.\\\"}}},\\\"HomePillars\\\":{\\\"badge\\\":\\\"Our pillars\\\",\\\"kicker\\\":\\\"02 — Strategic axes\\\",\\\"titleBefore\\\":\\\"What structures\\\",\\\"titleAccent\\\":\\\"our action\\\",\\\"intro\\\":\\\"Four complementary levers to turn ambitions into concrete projects, with rigor and long-term vision.\\\",\\\"tablistAria\\\":\\\"Strategic pillars\\\",\\\"pillarLabel\\\":\\\"Pillar {current} / {total}\\\",\\\"floatingBadge\\\":\\\"Integrated vision\\\",\\\"items\\\":{\\\"partnerships\\\":{\\\"title\\\":\\\"Strategic partnerships\\\",\\\"description\\\":\\\"We build lasting alliances with financial institutions, funders, and industrial players to secure supply chains, share expertise, and accelerate large-scale projects for national and regional development.\\\"},\\\"growth\\\":{\\\"title\\\":\\\"Economic growth\\\",\\\"description\\\":\\\"Our initiatives aim to strengthen local value chains, create skilled jobs, and support measurable, balanced growth in the regions where we invest—linking production, distribution, and market needs.\\\"},\\\"infrastructure\\\":{\\\"title\\\":\\\"Infrastructure\\\",\\\"description\\\":\\\"We contribute to resilient infrastructure—from structural works to urban equipment—while meeting technical standards, agreed timelines, and the quality and safety requirements of major construction sites.\\\"},\\\"innovation\\\":{\\\"title\\\":\\\"Innovation\\\",\\\"description\\\":\\\"We integrate material solutions, processes, and governance models that improve performance, traceability, and durability of structures, while staying aligned with international industry standards.\\\"}}},\\\"About\\\":{\\\"pageTitle\\\":\\\"About\\\",\\\"pageIntro\\\":\\\"International Business Alliance — materials, partnerships, and standards serving sustainable construction.\\\",\\\"mission\\\":{\\\"waterNumber\\\":\\\"01\\\",\\\"badge\\\":\\\"Our mission\\\",\\\"kicker\\\":\\\"01 — Our mission\\\",\\\"headline\\\":\\\"Supply, support, and\\\",\\\"headlineAccent\\\":\\\"build sustainably.\\\",\\\"intro\\\":\\\"Provide professionals and individuals with quality materials to ensure the success of their construction projects. We commit to offering tailored solutions, efficient service, and close support for every job site.\\\",\\\"narrativeTitle\\\":\\\"A force that builds the future\\\",\\\"narrativeLead\\\":\\\"We are the force that builds the future — trust that endures over time and across the globe.\\\",\\\"narrativeBody\\\":\\\"We do more than supply materials. We support partners and clients in delivering reliable, lasting projects, promoting transparency, safety, and quality.\\\",\\\"international\\\":{\\\"title\\\":\\\"International reach\\\",\\\"body\\\":\\\"IBA works with foreign and local partners and suppliers, and upholds international standards, enabling it to engage openly with the global construction materials market.\\\"}},\\\"vision\\\":{\\\"waterNumber\\\":\\\"02\\\",\\\"badge\\\":\\\"Our vision\\\",\\\"kicker\\\":\\\"02 — Our vision\\\",\\\"headline\\\":\\\"To be a partner of\\\",\\\"headlineAccent\\\":\\\"reference in construction.\\\",\\\"intro\\\":\\\"A future where every project, large or small, rests on solid materials and reliable supply. We aspire to become a key industry player by actively contributing to urban development and infrastructure modernization.\\\"},\\\"focusAreas\\\":{\\\"waterNumber\\\":\\\"03\\\",\\\"badge\\\":\\\"Our impact\\\",\\\"kicker\\\":\\\"03 — Focus areas\\\",\\\"headline\\\":\\\"Act with\\\",\\\"headlineAccent\\\":\\\"rigor and measure\\\",\\\"intro\\\":\\\"Three complementary levers to ground our mission in concrete results on the ground.\\\",\\\"cards\\\":{\\\"impact\\\":{\\\"title\\\":\\\"Targeted impact\\\",\\\"body\\\":\\\"IBA aims to sustainably improve the construction sector by supplying quality materials, contributing to infrastructure development, and supporting local and regional economic growth.\\\"},\\\"projects\\\":{\\\"title\\\":\\\"Our projects\\\",\\\"body\\\":\\\"A track record of sites and partnerships that demonstrate our ability to deliver, meet standards, and keep our operational commitments.\\\",\\\"ctaLabel\\\":\\\"Explore\\\"},\\\"governance\\\":{\\\"title\\\":\\\"Ethical governance\\\",\\\"body\\\":\\\"IBA practices transparent, responsible management grounded in integrity, respect for standards, legal compliance, and commitment to partners, employees, and clients.\\\"}}},\\\"charter\\\":{\\\"waterNumber\\\":\\\"04\\\",\\\"badge\\\":\\\"Our charter\\\",\\\"kicker\\\":\\\"04 — Values \\u0026 principles\\\",\\\"headline\\\":\\\"Our\\\",\\\"headlineAccent\\\":\\\"philosophy\\\",\\\"intro\\\":\\\"At IBA, we believe construction sector development rests on responsible management, strong partnerships, and a sustainable vision. Our approach values local expertise while aligning with international standards.\\\",\\\"principles\\\":{\\\"integrity\\\":\\\"Integrity and transparency\\\",\\\"sustainability\\\":\\\"Sustainable development\\\",\\\"innovation\\\":\\\"Collaborative innovation\\\",\\\"social\\\":\\\"Social responsibility\\\"}}},\\\"Products\\\":{\\\"heroBadge\\\":\\\"PRODUCTS\\\",\\\"heroTitle\\\":\\\"Product\\\",\\\"heroTitleAccent\\\":\\\"Catalog\\\",\\\"heroDescription\\\":\\\"A rigorous selection of premium construction materials. From structural works to specialized finishes, we equip your sites to international standards.\\\",\\\"categoriesHeading\\\":\\\"Product categories\\\",\\\"categoriesLabel\\\":\\\"Categories\\\",\\\"allProducts\\\":\\\"All products\\\",\\\"fullInventory\\\":\\\"Full inventory\\\",\\\"fullInventoryDesc\\\":\\\"Browse our full range of references available in stock.\\\",\\\"filterAria\\\":\\\"Filter by category\\\",\\\"closePreview\\\":\\\"Close preview\\\",\\\"close\\\":\\\"Close\\\",\\\"previousProduct\\\":\\\"Previous product\\\",\\\"nextProduct\\\":\\\"Next product\\\",\\\"expand\\\":\\\"expand\\\",\\\"enlargeImage\\\":\\\"Enlarge image: {name}\\\",\\\"openZoom\\\":\\\"Open enlarged view\\\",\\\"previousPage\\\":\\\"Previous page\\\",\\\"nextPage\\\":\\\"Next page\\\",\\\"noProducts\\\":\\\"No products found\\\",\\\"noProductsHint\\\":\\\"Please select another category.\\\",\\\"ctaTitleBefore\\\":\\\"Bulk orders \\u0026\\\",\\\"ctaTitleAccent\\\":\\\"quotes\\\",\\\"ctaDescription\\\":\\\"Need large quantities for your site? Contact our sa