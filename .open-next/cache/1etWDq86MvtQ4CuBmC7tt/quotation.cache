-4-4H9a4 4 0 0 0-4 4v2\"></path><circle cx=\"12\" cy=\"7\" r=\"4\"></circle></svg><input id=\"quote-name\" type=\"text\" required=\"\" autoComplete=\"name\" class=\"w-full border border-iba-sky/20 bg-background pl-12 pr-4 py-3 text-base font-medium text-iba-navy placeholder:text-iba-navy/35 focus:border-iba-navy focus:outline-none focus:ring-1 focus:ring-iba-navy transition-all\" placeholder=\"Jean Dupont\" name=\"name\"/></div></div><div class=\"space-y-2\"><label for=\"quote-company\" class=\"font-mono text-[10px] font-bold uppercase tracking-widest text-iba-navy/70\">Entreprise / Projet</label><div class=\"relative\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-building2 lucide-building-2 absolute left-4 top-1/2 -translate-y-1/2 h-4 w-4 text-iba-navy/45\" aria-hidden=\"true\"><path d=\"M10 12h4\"></path><path d=\"M10 8h4\"></path><path d=\"M14 21v-3a2 2 0 0 0-4 0v3\"></path><path d=\"M6 10H4a2 2 0 0 0-2 2v7a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-2\"></path><path d=\"M6 21V5a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v16\"></path></svg><input id=\"quote-company\" type=\"text\" autoComplete=\"organization\" class=\"w-full border border-iba-sky/20 bg-background pl-12 pr-4 py-3 text-base font-medium text-iba-navy placeholder:text-iba-navy/35 focus:border-iba-navy focus:outline-none focus:ring-1 focus:ring-iba-navy transition-all\" placeholder=\"Construction S.A.\" name=\"company\"/></div></div><div class=\"space-y-2\"><label for=\"quote-email\" class=\"font-mono text-[10px] font-bold uppercase tracking-widest text-iba-navy/70\">Adresse Email *</label><div class=\"relative\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-mail absolute left-4 top-1/2 -translate-y-1/2 h-4 w-4 text-iba-navy/45\" aria-hidden=\"true\"><path d=\"m22 7-8.991 5.727a2 2 0 0 1-2.009 0L2 7\"></path><rect x=\"2\" y=\"4\" width=\"20\" height=\"16\" rx=\"2\"></rect></svg><input id=\"quote-email\" required=\"\" type=\"email\" autoComplete=\"email\" class=\"w-full border border-iba-sky/20 bg-background pl-12 pr-4 py-3 text-base font-medium text-iba-navy placeholder:text-iba-navy/35 focus:border-iba-navy focus:outline-none focus:ring-1 focus:ring-iba-navy transition-all\" placeholder=\"contact@entreprise.com\" name=\"email\"/></div></div><div class=\"space-y-2\"><label for=\"quote-phone\" class=\"font-mono text-[10px] font-bold uppercase tracking-widest text-iba-navy/70\">Téléphone *</label><div class=\"relative\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-phone absolute left-4 top-1/2 -translate-y-1/2 h-4 w-4 text-iba-navy/45\" aria-hidden=\"true\"><path d=\"M13.832 16.568a1 1 0 0 0 1.213-.303l.355-.465A2 2 0 0 1 17 15h3a2 2 0 0 1 2 2v3a2 2 0 0 1-2 2A18 18 0 0 1 2 4a2 2 0 0 1 2-2h3a2 2 0 0 1 2 2v3a2 2 0 0 1-.8 1.6l-.468.351a1 1 0 0 0-.292 1.233 14 14 0 0 0 6.392 6.384\"></path></svg><input id=\"quote-phone\" required=\"\" type=\"tel\" inputMode=\"tel\" maxLength=\"80\" autoComplete=\"tel\" class=\"w-full border border-iba-sky/20 bg-background pl-12 pr-4 py-3 text-base font-medium text-iba-navy placeholder:text-iba-navy/35 focus:border-iba-navy focus:outline-none focus:ring-1 focus:ring-iba-navy transition-all\" placeholder=\"+243 ...\" name=\"phone\"/></div></div></div></div><div class=\"relative border border-iba-sky/15 bg-white p-8 md:p-12 shadow-[0_10px_40px_rgba(40,37,97,0.03)]\"><div class=\"absolute top-0 left-0 w-3 h-3 border-t-2 border-l-2 border-iba-sky\"></div><div class=\"absolute top-0 right-0 w-3 h-3 border-t-2 border-r-2 border-iba-sky\"></div><div class=\"absolute bottom-0 left-0 w-3 h-3 border-b-2 border-l-2 border-iba-sky\"></div><div class=\"absolute bottom-0 right-0 w-3 h-3 border-b-2 border-r-2 border-iba-sky\"></div><div class=\"mb-8 flex items-end gap-4 border-b border-iba-sky/10 pb-4\"><span class=\"font-mono text-4xl font-black text-iba-navy/12\">02</span><h2 class=\"text-2xl font-black uppercase tracking-tighter text-iba-navy\">Votre demande</h2></div><div class=\"space-y-2\"><textarea id=\"quote-request\" name=\"request\" required=\"\" rows=\"8\" class=\"w-full border border-iba-sky/20 bg-background p-4 text-base font-medium text-iba-navy placeholder:text-iba-navy/35 focus:border-iba-navy focus:outline-none focus:ring-1 focus:ring-iba-navy transition-all resize-y min-h-[180px]\" placeholder=\"Décrivez librement ce dont vous avez besoin : types de matériaux, quantités approximatives, références, dimensions, etc.\"></textarea></div></div><div class=\"flex justify-end lg:justify-start\"><button type=\"submit\" disabled=\"\" class=\"group relative inline-flex items-center justify-center overflow-hidden border-2 bg-iba-orange px-10 py-5 font-mono text-sm font-bold uppercase tracking-widest text-white transition-all opacity-50 cursor-not-allowed border-iba-orange\"><span class=\"relative z-10 flex items-center\">Soumettre le Manifeste<svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-send ml-3 h-4 w-4 transition-transform duration-300 group-hover:-translate-y-1 group-hover:translate-x-1\" aria-hidden=\"true\"><path d=\"M14.536 21.686a.5.5 0 0 0 .937-.024l6.5-19a.496.496 0 0 0-.635-.635l-19 6.5a.5.5 0 0 0-.024.937l7.93 3.18a2 2 0 0 1 1.112 1.11z\"></path><path d=\"m21.854 2.147-10.94 10.939\"></path></svg></span></button></div></form><aside class=\"hidden lg:col-span-1 lg:block\"><div class=\"sticky top-28 space-y-10 border