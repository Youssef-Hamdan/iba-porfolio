# Copier vers .env.local (non versionné) et renseigner les valeurs.
# Resend : https://resend.com/api-keys

RESEND_API_KEY=
# Adresse qui reçoit chaque demande de devis
QUOTE_TO_EMAIL=commercial@rdcsteel.com
# Expéditeur : avec domaine vérifié sur Resend, ex. "IBA <devis@votredomaine.com>"
# Sans domaine : tests avec "IBA Devis <onboarding@resend.dev>" — dans ce cas Resend
# n’autorise la livraison qu’à l’e-mail du compte Resend (QUOTE_TO_EMAIL identique),
# sauf après vérification d’un domaine + from @ce-domaine (voir erreurs API Resend).
RESEND_FROM_EMAIL=IBA Devis <onboarding@resend.dev>
